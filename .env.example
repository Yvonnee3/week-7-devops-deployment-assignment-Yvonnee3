# ==============================================
# MERN Stack Application Environment Variables
# ==============================================

# Application Environment
NODE_ENV=development

# ==============================================
# BACKEND CONFIGURATION
# ==============================================

# Server Configuration
BACKEND_PORT=5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/mern-deployment-app
MONGODB_URI_TEST=mongodb://localhost:27017/mern-test

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=30d

# ==============================================
# FRONTEND CONFIGURATION
# ==============================================

# Frontend Port
FRONTEND_PORT=3000

# API URL (for frontend to connect to backend)
VITE_API_URL=http://localhost:5000/api

# ==============================================
# DEPLOYMENT CONFIGURATION
# ==============================================

# Docker Registry
DOCKER_REGISTRY=your-registry.com

# Domain Configuration
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Production URLs (update these for production)
PROD_FRONTEND_URL=https://your-app.com
PROD_BACKEND_URL=https://api.your-app.com

# ==============================================
# MONITORING CONFIGURATION
# ==============================================

# Logging
LOG_LEVEL=info

# Metrics and Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn_here

# ==============================================
# SECURITY CONFIGURATION
# ==============================================

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==============================================
# EMAIL CONFIGURATION (Optional)
# ==============================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ==============================================
# FILE UPLOAD CONFIGURATION
# ==============================================

MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ==============================================
# REDIS CONFIGURATION (Optional)
# ==============================================

REDIS_URL=redis://localhost:6379

# ==============================================
# PRODUCTION DATABASE (MongoDB Atlas)
# ==============================================

# Uncomment and configure for production
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ==============================================
# CI/CD SECRETS (GitHub Actions)
# ==============================================

# These should be set as GitHub Secrets, not in this file
# RENDER_API_KEY=your_render_api_key
# RENDER_SERVICE_ID=your_render_service_id
# VERCEL_TOKEN=your_vercel_token
# VERCEL_ORG_ID=your_vercel_org_id
# VERCEL_PROJECT_ID=your_vercel_project_id